{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "frs/directory-filters",
  "version": "1.0.0",
  "title": "Directory Filters",
  "category": "frs-blocks",
  "icon": "filter",
  "description": "Service area filter chips for the loan officer directory. Works with Directory Search and Directory Grid blocks.",
  "keywords": [
    "filter",
    "directory",
    "loan officer",
    "service areas",
    "states"
  ],
  "textdomain": "frs-users",
  "supports": {
    "html": false,
    "interactivity": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "default": "Service Areas"
    },
    "hint": {
      "type": "string",
      "default": "Click to filter by service area"
    },
    "showClearButton": {
      "type": "boolean",
      "default": true
    }
  },
  "editorScript": "file:./index.js",
  "viewScriptModule": "file:./view.js",
  "render": "file:./render.php"
}